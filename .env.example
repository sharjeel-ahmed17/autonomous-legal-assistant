APP_NAME="Autonomous Legal Assistant"
APP_VERSION="0.1.0"
APP_ENV="development" # in production use "production"
DEBUG="true" # in production "false"

HOST="127.0.0.1"
PORT="8000"

SECRET_KEY="replace-with-a-long-random-secret-key"
ACCESS_TOKEN_EXPIRE_MINUTES="30"

DATABASE_URL="sqlite:///./legal_assistant.db" # in production use PostgreSQL connection string

REDIS_URL="redis://localhost:6379/0"

QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="legal_documents"

OPENAI_API_KEY=""
GROQ_API_KEY=""
COHERE_API_KEY=""

CHAT_MODEL="llama-3.3-70b-versatile"
EMBEDDING_MODEL="embed-v4.0"

LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="autonomous-legal-assistant"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"

UPLOAD_DIR="data/uploads"
MAX_UPLOAD_SIZE_MB="50"

OCR_PROVIDER="groq"
OCR_MODEL="meta-llama/llama-4-maverick-17b-128e-instruct"

TOP_K="5"
CHUNK_SIZE="1000"
CHUNK_OVERLAP="200"

LOG_LEVEL="INFO"

BACKEND_CORS_ORIGINS="http://localhost:3000"

MCP_ENABLED="true"

MCP_FILESYSTEM_SERVER=""
MCP_POSTGRES_SERVER=""
MCP_GOOGLE_DRIVE_SERVER=""
MCP_WORD_SERVER=""
MCP_EMAIL_SERVER=""
MCP_CALENDAR_SERVER=""
